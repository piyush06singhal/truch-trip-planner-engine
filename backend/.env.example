# Django settings
DEBUG=True
SECRET_KEY=generate_a_random_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Supabase PostgreSQL Connection Pooler (Port 6543)
DB_HOST=aws-0-us-east-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.[PROJECT_REF_ID]
DB_PASSWORD=[YOUR_SUPABASE_PASSWORD]
DATABASE_URL=postgresql://postgres.[PROJECT_REF_ID]:[YOUR_SUPABASE_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
